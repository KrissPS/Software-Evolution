IDENTIFICATION DIVISION.
PROGRAM-ID. EVAL-CONTRACTED.

DATA DIVISION.
01 X PICTURE IS 99.
01 Y PICTURE IS 99.
01 Z PICTURE IS 99.
01 COUNTER PICTURE IS 99.
01 RESULT PICTURE IS 99.

PROCEDURE DIVISION.
    MOVE 0 TO COUNTER
    MOVE 0 TO RESULT

    MOVE 10 TO X
    EVALUATE X
        WHEN 10 OR 20 OR 30
            DISPLAY "MATCHED OR VALUES"
            ADD 1 TO COUNTER
        WHEN OTHER
            DISPLAY "NO MATCH"
    END

    MOVE 25 TO X
    EVALUATE X
        WHEN 10 OR 20 OR 30
            DISPLAY "SHOULD NOT APPEAR"
        WHEN OTHER
            DISPLAY "OTHER CAUGHT"
            ADD 1 TO COUNTER
    END

    MOVE 15 TO X
    EVALUATE X
        WHEN 10 THROUGH 20 OR 30 THROUGH 40
            DISPLAY "MATCHED THROUGH RANGE OR"
            ADD 1 TO COUNTER
        WHEN OTHER
            DISPLAY "NO RANGE MATCH"
    END

    MOVE 45 TO X
    EVALUATE X
        WHEN 10 THROUGH 20 OR 30 THROUGH 40
            DISPLAY "SHOULD NOT MATCH RANGE"
        WHEN OTHER
            DISPLAY "RANGE OTHER CAUGHT"
            ADD 1 TO COUNTER
    END

    MOVE 5 TO X
    MOVE 25 TO Y
    EVALUATE X ALSO Y
        WHEN 5 ALSO 25
            DISPLAY "ALSO MATCH"
            ADD 1 TO COUNTER
        WHEN OTHER
            DISPLAY "ALSO NO MATCH"
    END

    MOVE 12 TO X
    EVALUATE TRUE
        WHEN X > 10 AND X < 20
            DISPLAY "TRUE CONDITION MATCH"
            ADD 1 TO COUNTER
        WHEN OTHER
            DISPLAY "TRUE OTHER"
    END

    MOVE 8 TO X
    EVALUATE TRUE
        WHEN X < 5 OR X > 10
            DISPLAY "TRUE OR SHOULD NOT MATCH"
        WHEN OTHER
            DISPLAY "TRUE OR OTHER"
            ADD 1 TO COUNTER
    END

    MOVE 3 TO X
    EVALUATE TRUE
        WHEN X < 5 OR X > 10
            DISPLAY "TRUE OR MATCH"
            ADD 1 TO COUNTER
        WHEN OTHER
            DISPLAY "TRUE OR OTHER 2"
    END

    MOVE COUNTER TO RESULT
    DISPLAY "FINAL COUNTER IS " COUNTER
    STOP.